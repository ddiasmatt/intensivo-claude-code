---
import { CONFIG } from '../config';
---
<header class="sticky top-0 z-40" role="banner">
  <a
    href="#final-cta"
    class="block bg-accent text-page font-mono text-[11px] tracking-widest py-4 text-center hover:bg-accent-hover transition-colors"
  >
    <span
      class="inline-block w-1.5 h-1.5 rounded-full bg-page mr-2 align-middle animate-live-pulse"
      aria-hidden="true"
    ></span>
    {CONFIG.TOPBAR_TEXT}
  </a>
</header>
