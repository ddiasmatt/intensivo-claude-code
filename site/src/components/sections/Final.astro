---
import { CONFIG } from '@/config';
import { HoverBorderGradient } from '@/components/ui/hover-border-gradient';
---

<section id="final" class="relative overflow-hidden py-24 md:py-32" data-gsap="reveal">
  <div class="dot-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[520px] w-[520px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/12 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div class="container-landing relative">
    <div class="mx-auto max-w-3xl text-center">
      <h2
        class="text-4xl font-bold leading-tight tracking-tight text-ink-primary md:text-5xl lg:text-6xl"
      >
        {CONFIG.URGENCY_TITLE}
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink-secondary md:text-lg">
        {CONFIG.URGENCY_SUBTITLE}
      </p>
      <div class="mt-10 flex justify-center" data-magnetic>
        <HoverBorderGradient
          client:load
          data-open-modal
          as="button"
          containerClassName="rounded-2xl"
          className="rounded-2xl bg-page text-white font-bold text-lg sm:text-xl md:text-2xl px-10 py-5 tracking-wide"
        >
          {CONFIG.FINAL_CTA}
        </HoverBorderGradient>
      </div>
      <p class="mt-6 text-xs text-ink-muted sm:text-sm">
        Sabado 16/05 · 09h as 16h · Zoom ao vivo com gravacao liberada.
      </p>
    </div>
  </div>
</section>
