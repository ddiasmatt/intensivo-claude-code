---
import { CONFIG } from '../../config';
---
<section id="final-cta" class="relative border-t border-rule py-24 sm:py-36 bg-surface">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <h2 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.02] text-ink-primary mb-6">
      {CONFIG.FINALCTA_HEADLINE}
    </h2>

    <p class="font-sans text-lg sm:text-xl text-ink-secondary leading-relaxed mb-12 max-w-2xl mx-auto">
      {CONFIG.FINALCTA_SUBHEADLINE}
    </p>

    <button
      type="button"
      data-open-modal
      data-cta-location="final"
      class="inline-flex items-center gap-3 bg-accent hover:bg-accent-hover text-page font-mono text-sm tracking-widest uppercase px-10 py-5 transition-colors"
    >
      {CONFIG.FINALCTA_BUTTON}
    </button>

    <p class="mt-5 font-mono text-xs text-ink-muted tracking-wide">
      {CONFIG.FINALCTA_MICROCOPY}
    </p>

  </div>
</section>
