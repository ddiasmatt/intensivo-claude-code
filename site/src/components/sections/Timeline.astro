---
import { CONFIG } from '@/config';
import TimelineWrapper from '@/components/react/TimelineWrapper';
---

<section id="timeline" class="relative py-20 md:py-28" data-gsap="reveal">
  <div class="container-landing">
    <div class="mb-10 max-w-3xl text-center md:mx-auto md:mb-14">
      <span
        class="glass-chip mx-auto font-mono text-[10px] uppercase tracking-[0.22em] text-accent-hover"
      >
        <span class="h-1 w-1 rounded-full bg-accent"></span>
        {CONFIG.TIMELINE_TAG}
      </span>
      <h2
        class="mx-auto mt-5 text-3xl font-bold tracking-tight text-ink-primary md:text-4xl lg:text-5xl"
      >
        {CONFIG.TIMELINE_TITLE}
      </h2>
      <p class="mx-auto mt-4 text-base text-ink-secondary md:text-lg">
        {CONFIG.TIMELINE_SUBTITLE}
      </p>
    </div>

    <TimelineWrapper client:visible blocks={CONFIG.TIMELINE_BLOCKS} />

    <p class="mx-auto mt-4 max-w-2xl text-center text-sm text-ink-muted md:text-base">
      {CONFIG.TIMELINE_FOOTER}
    </p>

    <div
      class="mx-auto mt-16 grid max-w-4xl gap-8 overflow-hidden rounded-3xl border border-white/10 bg-surface/60 p-8 backdrop-blur-sm md:grid-cols-[auto_1fr] md:p-10"
    >
      <img
        src="/mateus.webp"
        alt="Mateus Dias"
        loading="lazy"
        width="180"
        height="180"
        class="mx-auto h-36 w-36 rounded-2xl border border-accent/25 object-cover shadow-[0_20px_60px_-25px_rgba(224,122,58,0.4)] md:mx-0 md:h-44 md:w-44"
      />
      <div>
        <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-accent-hover">
          {CONFIG.PRESENTER_TITLE}
        </p>
        <h3 class="mt-2 text-2xl font-bold text-ink-primary md:text-3xl">
          {CONFIG.PRESENTER_NAME}
        </h3>
        <div class="mt-4 whitespace-pre-line text-sm leading-relaxed text-ink-secondary md:text-base">
          {CONFIG.PRESENTER_BIO}
        </div>
      </div>
    </div>
  </div>
</section>
