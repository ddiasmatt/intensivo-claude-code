---
import { CONFIG } from '../config';
---
<header class="sticky top-0 z-40" role="banner">
  <a
    href="#final-cta"
    class="block bg-accent text-page font-sans font-bold text-sm sm:text-base tracking-wide py-5 text-center hover:bg-accent-hover transition-colors uppercase"
  >
    <span
      class="inline-block w-2 h-2 rounded-full bg-page mr-2.5 align-middle animate-live-pulse"
      aria-hidden="true"
    ></span>
    {CONFIG.TOPBAR_TEXT}
  </a>
</header>
