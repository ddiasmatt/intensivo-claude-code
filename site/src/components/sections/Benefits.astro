---
import { CONFIG } from '@/config';
import BenefitCard from '@/components/react/BenefitCard';
---

<section id="benefits" class="relative py-20 md:py-28" data-gsap="reveal">
  <div class="container-landing">
    <div class="mb-10 max-w-3xl text-center md:mb-14">
      <span
        class="glass-chip mx-auto font-mono text-[10px] uppercase tracking-[0.22em] text-accent-hover"
      >
        <span class="h-1 w-1 rounded-full bg-accent"></span>
        {CONFIG.BENEFITS_TAG}
      </span>
      <h2
        class="mx-auto mt-5 text-3xl font-bold tracking-tight text-ink-primary md:text-4xl lg:text-5xl"
      >
        {CONFIG.BENEFITS_TITLE}
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        CONFIG.BENEFITS.map((benefit) => (
          <BenefitCard client:visible benefit={benefit} />
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <button
        type="button"
        data-open-modal
        class="cta-button relative overflow-hidden text-base sm:text-lg"
      >
        <span class="shimmer-overlay" aria-hidden="true"></span>
        <span class="relative">{CONFIG.BENEFITS_CTA}</span>
      </button>
    </div>
  </div>
</section>
