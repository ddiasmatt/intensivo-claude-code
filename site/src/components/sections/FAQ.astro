---
import { CONFIG } from '@/config';
import FAQList from '@/components/react/FAQList';
---

<section id="faq" class="relative py-20 md:py-28" data-gsap="reveal">
  <div class="container-landing max-w-4xl">
    <div class="mb-10 text-center md:mb-14">
      <span
        class="glass-chip mx-auto font-mono text-[10px] uppercase tracking-[0.22em] text-accent-hover"
      >
        <span class="h-1 w-1 rounded-full bg-accent"></span>
        {CONFIG.FAQ_TAG}
      </span>
      <h2
        class="mx-auto mt-5 text-3xl font-bold tracking-tight text-ink-primary md:text-4xl lg:text-5xl"
      >
        {CONFIG.FAQ_TITLE}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-ink-secondary md:text-lg">
        {CONFIG.FAQ_SUBTITLE}
      </p>
    </div>

    <FAQList client:visible items={CONFIG.FAQ_ITEMS} />
  </div>
</section>
