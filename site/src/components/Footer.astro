---
import { CONFIG } from '../config';
---
<footer class="border-t border-rule bg-page py-10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">

      <!-- Logo mono -->
      <span class="font-mono text-sm tracking-widest text-ink-primary uppercase">
        GRUPO VUK
      </span>

      <!-- Links legais + contato -->
      <nav class="flex flex-wrap items-center justify-center gap-4 sm:gap-6 font-mono text-xs text-ink-muted">
        <!-- TODO: URL legal pendente -->
        <a href="#" class="hover:text-ink-secondary transition-colors">Política de Privacidade</a>
        <!-- TODO: URL legal pendente -->
        <a href="#" class="hover:text-ink-secondary transition-colors">Termos de Uso</a>
        <a href="mailto:contato@grupovuk.com.br" class="hover:text-ink-secondary transition-colors">
          contato@grupovuk.com.br
        </a>
      </nav>

    </div>

    <p class="mt-6 text-center font-mono text-xs text-ink-muted">
      {CONFIG.COPYRIGHT}
    </p>

  </div>
</footer>
