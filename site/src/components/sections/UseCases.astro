---
import UseCasesGrid from '@/components/react/UseCasesGrid';
import { FileText, MessageSquare, BarChart3, Rocket } from 'lucide-react';

const useCases = [
  {
    name: 'De roteiro a post publicado em 40min.',
    description:
      'Claude Code escreve, Mateus revisa. Voce publica 3x mais conteudo sem triplicar equipe.',
    Icon: FileText,
    href: '#final',
    cta: 'Ver exemplos',
    className: 'col-span-3 lg:col-span-2',
  },
  {
    name: 'Leads respondidos em 2min, 24h.',
    description:
      'Integrado ao ChatFunnel, qualifica, responde e agenda reuniao. Sem perder lead quente no fim de semana.',
    Icon: MessageSquare,
    href: '#final',
    cta: 'Ver fluxo',
    className: 'col-span-3 lg:col-span-1',
  },
  {
    name: 'KPIs compilados automaticamente.',
    description:
      'Dashboard diario chega no seu WhatsApp. Voce decide, o agente coleta os numeros.',
    Icon: BarChart3,
    href: '#final',
    cta: 'Ver dashboard',
    className: 'col-span-3 lg:col-span-1',
  },
  {
    name: 'Onboarding de cliente rodando sozinho.',
    description:
      'Boas-vindas, acesso, setup, checkin. A esteira toda tocada pelo Claude com zero toque humano.',
    Icon: Rocket,
    href: '#final',
    cta: 'Ver automacao',
    className: 'col-span-3 lg:col-span-2',
  },
];
---

<section id="use-cases" class="relative py-20 md:py-28" data-gsap="reveal">
  <div class="container-landing">
    <div class="mb-10 max-w-3xl text-center md:mb-14 md:text-left">
      <span
        class="glass-chip font-mono text-[10px] uppercase tracking-[0.22em] text-accent-hover"
      >
        <span class="h-1 w-1 rounded-full bg-accent"></span>
        4 frentes de aplicacao
      </span>
      <h2
        class="mt-5 text-3xl font-bold tracking-tight text-ink-primary md:text-4xl lg:text-5xl"
      >
        O que voce vai estar rodando ate sabado a noite.
      </h2>
      <p class="mt-4 text-base text-ink-secondary md:text-lg">
        Cada frente e um squad de IA que voce configura ao vivo no dia. Sai pronto pra ligar.
      </p>
    </div>

    <UseCasesGrid client:visible cards={useCases} />
  </div>
</section>
