---
import { CONFIG } from '@/config';
import { Spotlight } from '@/components/blocks/spotlight-new';
import { BackgroundBeams } from '@/components/ui/background-beams';
import { HoverBorderGradient } from '@/components/ui/hover-border-gradient';
import AgentSwarm from '@/components/react/AgentSwarm';
---

<section
  id="hero"
  class="relative isolate overflow-hidden pt-12 pb-20 md:pt-20 md:pb-28 lg:pt-24 lg:pb-32"
>
  <Spotlight
    client:load
    gradientFirst="radial-gradient(68.54% 68.72% at 55.02% 31.46%, hsla(25, 85%, 55%, .18) 0, hsla(25, 85%, 55%, .05) 50%, hsla(25, 85%, 55%, 0) 80%)"
    gradientSecond="radial-gradient(50% 50% at 50% 50%, hsla(25, 85%, 55%, .12) 0, hsla(25, 85%, 55%, .04) 80%, transparent 100%)"
    gradientThird="radial-gradient(50% 50% at 50% 50%, hsla(25, 85%, 55%, .08) 0, hsla(25, 85%, 55%, .02) 80%, transparent 100%)"
  />

  <div class="pointer-events-none absolute inset-0 grid-overlay" aria-hidden="true"></div>

  <div class="container-landing relative z-10">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <div
        class="mb-5 inline-flex items-center gap-2.5 rounded-full border border-accent/30 bg-accent/10 px-4 py-2"
        data-gsap="hero-badge"
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-live-ring rounded-full bg-accent"></span>
          <span class="relative inline-flex h-2 w-2 animate-live-pulse rounded-full bg-accent"></span>
        </span>
        <span class="text-[11px] font-semibold uppercase tracking-widest text-accent-hover sm:text-xs">
          {CONFIG.EVENT_BADGE}
        </span>
      </div>

      <div class="mb-6 flex items-center gap-3" data-gsap="hero-wordmark">
        <span class="h-px w-8 bg-gradient-to-r from-transparent to-accent/60 sm:w-10"></span>
        <p class="font-mono text-[13px] font-bold uppercase tracking-[0.22em] text-accent sm:text-sm md:text-base">
          {CONFIG.EVENT_NAME}
        </p>
        <span class="h-px w-8 bg-gradient-to-l from-transparent to-accent/60 sm:w-10"></span>
      </div>

      <h1
        class="mb-6 text-[2rem] font-bold leading-[1.08] tracking-tight text-ink-primary sm:text-4xl md:text-5xl lg:text-[3.5rem] xl:text-6xl"
        data-gsap="hero-headline"
      >
        {CONFIG.HEADLINE_PART1}
        <span
          class="italic text-accent-gradient"
          style="font-family: Georgia, serif; font-weight: 500;"
        >
          {CONFIG.HEADLINE_HIGHLIGHT}
        </span>
        {CONFIG.HEADLINE_PART2}
      </h1>

      <p
        class="mb-2 max-w-2xl text-base leading-relaxed text-ink-secondary sm:text-lg md:text-xl"
        data-gsap="hero-sub"
      >
        {CONFIG.SUBHEADLINE}
      </p>
      <p class="mb-8 max-w-2xl text-sm italic leading-relaxed text-ink-muted sm:text-base">
        {CONFIG.ICP_LINE}
      </p>

      <div
        class="mb-6 inline-flex items-center gap-3 rounded-full border border-accent/25 bg-surface/60 py-2 pl-3 pr-5 backdrop-blur-sm"
        data-gsap="hero-price"
      >
        <span
          class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-accent/15"
        >
          <svg
            class="h-3.5 w-3.5 text-accent-hover"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0110 0v4"></path>
          </svg>
        </span>
        <p class="text-xs font-medium leading-tight text-ink-primary sm:text-sm">
          <span class="font-bold text-accent-hover">Oferta unica de R$27.</span>
          <span class="text-ink-secondary">Entre no grupo para receber.</span>
        </p>
      </div>

      <div class="mb-4" data-gsap="hero-cta" data-magnetic>
        <HoverBorderGradient
          client:load
          data-open-modal
          as="button"
          containerClassName="rounded-2xl"
          className="rounded-2xl bg-page text-white font-bold text-lg sm:text-xl md:text-2xl px-10 py-5 tracking-wide"
        >
          <span class="inline-flex items-center gap-3 sm:gap-4">
            {CONFIG.CTA_TEXT}
            <span
              class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/80 text-white transition-all duration-300 sm:h-9 sm:w-9"
            >
              <svg class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </span>
        </HoverBorderGradient>
      </div>

      <p class="mb-8 text-xs font-medium text-ink-muted sm:text-sm">{CONFIG.CTA_REINFORCEMENT}</p>

      <div
        class="mb-14 flex flex-col items-center gap-y-2 gap-x-6 sm:flex-row sm:justify-center md:mb-16"
      >
        {
          CONFIG.OBJECTIONS.map((objection) => (
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent"></span>
              <span class="text-xs font-medium leading-tight text-ink-secondary sm:text-sm">
                {objection}
              </span>
            </div>
          ))
        }
      </div>

      <div class="w-full max-w-4xl" data-gsap="hero-diagram">
        <div class="relative glass-card p-6 sm:p-8 md:p-10">
          <div class="mb-5 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              <p class="text-[11px] font-semibold uppercase tracking-widest text-accent-hover sm:text-xs">
                O Sistema 10x
              </p>
            </div>
            <p class="font-mono text-[10px] tracking-wider text-ink-muted sm:text-[11px]">/live</p>
          </div>

          <AgentSwarm client:visible />

          <p class="mx-auto mt-6 max-w-md text-center text-sm leading-relaxed text-ink-secondary">
            {CONFIG.DIAGRAM_CAPTION}
          </p>
        </div>
      </div>
    </div>
  </div>

  <BackgroundBeams client:visible className="opacity-30" />
</section>
