# Landing ICC — variaveis PUBLIC_* sao injetadas no bundle client pelo Vite.
# Nao coloque segredos server-side aqui.

# Tracking
PUBLIC_GA_ID=G-XXXXXXXXXX
PUBLIC_META_PIXEL_ID=000000000000000

# Captura de lead: lista de webhooks separada por virgula, todos disparam em paralelo (fire-and-forget)
PUBLIC_WEBHOOK_URLS=https://example.com/webhook-1,https://example.com/webhook-2

# Destino pos-submit (UTMs sao propagados)
PUBLIC_REDIRECT_URL=https://example.com/obrigado
