---
import Base from '@/layouts/Base.astro';
import TopBar from '@/components/sections/TopBar.astro';
import Hero from '@/components/sections/Hero.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import UseCases from '@/components/sections/UseCases.astro';
import Benefits from '@/components/sections/Benefits.astro';
import Timeline from '@/components/sections/Timeline.astro';
import Final from '@/components/sections/Final.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Footer from '@/components/sections/Footer.astro';
import CaptureModal from '@/components/react/CaptureModal';

const title = 'Intensivo Claude Code: produza por 10 pessoas em 1 sabado';
const description =
  'Evento ao vivo sabado 16/05 no Zoom. Um dia para montar o Sistema 10x com Claude Code. Oferta unica de R$27 para quem entra no grupo.';
---

<Base title={title} description={description}>
  <TopBar />
  <main id="main">
    <Hero />
    <Testimonials />
    <UseCases />
    <Benefits />
    <Timeline />
    <Final />
    <FAQ />
    <Footer />
  </main>
  <CaptureModal client:load />
</Base>

<script>
  import '@/scripts/gsap-init';
</script>
